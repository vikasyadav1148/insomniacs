add_action('init', function() {
    add_rewrite_endpoint('release-schedule', EP_PAGES);
});
add_action('woocommerce_account_release-schedule_endpoint', function() {
    echo '&lt;h3&gt;Release Schedule Planner&lt;/h3&gt;';
