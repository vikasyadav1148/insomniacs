                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Tab 1: WooCommerce My Account integration -->
                    <div class="bg-neutral-950 border border-neutral-850 p-4 rounded-xl flex flex-col gap-2">
                        <div class="flex items-center gap-2 border-b border-neutral-850 pb-2 text-[11px] font-bold text-white uppercase tracking-wider font-mono text-red-400">
