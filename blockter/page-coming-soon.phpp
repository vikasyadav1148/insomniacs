                        <pre class="bg-black/45 border border-neutral-850 p-2.5 rounded-lg text-[9.5px] font-mono text-neutral-300 overflow-x-auto whitespace-pre select-all">add_filter('wp_get_nav_menu_items', function($items, $menu) {
